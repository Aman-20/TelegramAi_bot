# ─────────────────────────────────────────────
#  ✅ REQUIRED — Bot will NOT start without these
# ─────────────────────────────────────────────

TELEGRAM_TOKEN=           # Your Telegram bot token from @BotFather
ADMIN_ID=                 # Your Telegram numeric user ID (get it from @userinfobot)
MONGODB_CONNECT=          # MongoDB Atlas connection string (mongodb+srv://...)
RENDER_URL=               # Your full Render app URL (e.g. https://your-app.onrender.com)

# At least ONE AI key is required — Gemini is the default model
GEMINI_API_KEY=           # Google Gemini API key (default model — highly recommended)


# ─────────────────────────────────────────────
#  ✅ REQUIRED if you use Gemini (set model names)
#  These are the model string IDs sent to the Gemini API.
#  Leave blank only if you're not using Gemini at all.
# ─────────────────────────────────────────────

GEMINI_MODEL_1=gemini-2.0-flash        # Default / primary model (gemini)
GEMINI_MODEL_2=gemini-2.0-flash-lite   # gemini_flash2
GEMINI_MODEL_3=gemini-1.5-flash        # gemini_flash1
GEMINI_MODEL_4=gemini-1.5-pro          # gemini_pro (counts toward PRO_LIMIT)
GEMINI_MODEL_5=gemini-2.0-flash-exp    # gemini_flash3 (experimental)


# ─────────────────────────────────────────────
#  🔧 OPTIONAL AI Keys — only add what you want to offer
# ─────────────────────────────────────────────

OPENAI_API_KEY=           # Required only if you want to offer OpenAI models
OPENAI_MODEL_1=gpt-4o     # OpenAI model string (e.g. gpt-4o, gpt-3.5-turbo)

CLAUDE_API_KEY=           # Required only if you want to offer Anthropic Claude
CLAUDE_MODEL_1=claude-sonnet-4-6  # Claude model string

SERPER_API_KEY=           # Required for the 🔍 Search feature (serper.dev)


# ─────────────────────────────────────────────
#  ⚙️ IMPORTANT — Has defaults, but you should review these
# ─────────────────────────────────────────────

PORT=3000                          # Server port (Render sets this automatically)
FORCE_JOIN_CHANNEL=                # e.g. @YourChannel — leave blank to disable channel gate

DAILY_REQUEST_LIMIT=50             # Max AI requests per user per day
DAILY_TOKEN_LIMIT=50000            # Max tokens per user per day
MAX_REPLY_TOKENS=1024              # Max tokens per single AI reply

SEARCH_LIMIT=10                    # Max web searches per user per day
IMAGINE_LIMIT=5                    # Max image generations per user per day
LIMIT_DOC_ANALYSIS=5              # Max document analyses per user per day
LIMIT_IMG_ANALYSIS=10             # Max image analyses per user per day
LIMIT_PRO_MODEL=10                # Max uses of the Pro (Gemini Pro) model per user per day

APPROVAL_EXPIRY_HOURS=24          # How long an /approve lasts (in hours)


# ─────────────────────────────────────────────
#  🔧 OPTIONAL — Fine-tuning / advanced config
#  Safe to leave at defaults unless you have specific needs
# ─────────────────────────────────────────────

# Rate limiting (values are in SECONDS, converted to ms internally)
RATE_LIMIT_MS=3                   # Cooldown between regular messages (seconds)
COMMAND_LIMIT_MS=5                # Cooldown between commands (seconds)
LIMIT_MEDIA_COOLDOWN=10          # Cooldown between media/document uploads (seconds)

# Concurrency
MAX_CONCURRENT_REQUESTS=20        # Max simultaneous AI requests being processed
REQUEST_QUEUE_LIMIT=100           # Max requests allowed to queue up

# Memory & cache
MEMORY_CACHE_CLEAR_MINUTES=30    # How often in-memory caches are swept
MEMBERSHIP_CACHE_MINUTES=10      # How long channel membership is cached
APPROVAL_CACHE_SECONDS=60        # How long approval status is cached (short = faster revocation)

# Chat history
HISTORY_MESSAGES=10               # Messages sent as context to AI per request
DB_MSG_LIMIT=20                  # Max messages stored per user in DB
CHAT_HISTORY_TTL_DAYS=30        # Auto-delete chat history after N days of inactivity
MAX_HISTORY_CHARS=500            # Max characters stored per history message (keeps DB small)

# Documents
MAX_FILE_MB=10                   # Max file size allowed for uploads (MB)
DOC_CHAR_LIMIT=10000            # Max characters extracted from a document for AI context

# Database cleanup
INACTIVE_USER_DELETE_DAYS=90    # Auto-delete user records after N days of inactivity

# Timeouts
API_TIMEOUT_MS=30000            # AI API call timeout in milliseconds
